{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aidea",
  "version": "0.1.0",
  "identifier": "com.aidea.gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "aidea",
        "label": "main",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "DeveloperTool",
    "shortDescription": "aidea 自包含 AI IDE（端模型 + 在线厂商）",
    "longDescription": "单一 .dmg 自包含 GUI：本地 Ollama 端模型零配置对话 + OpenAI 兼容在线厂商路由，内嵌 PostgreSQL 与 aidea serve。",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "resources/"
    ],
    "externalBin": [
      "bin/aidea",
      "bin/ollama",
      "bin/postgres",
      "bin/initdb",
      "bin/pg_ctl",
      "bin/psql"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "hardening": true,
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  }
}
